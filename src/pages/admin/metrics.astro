---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Metrics (AdSense)">
	<div class="space-y-6">
		<section class="admin-surface rounded-3xl p-5 sm:p-7">
			<p class="text-xs font-semibold uppercase tracking-[0.16em] admin-muted">Revenue Analytics</p>
			<h1 class="mt-2 text-2xl sm:text-3xl font-bold tracking-tight">Google AdSense Metrics</h1>
			<p class="admin-muted mt-2 max-w-3xl">
				This page is ready for AdSense integration. Connect your reporting pipeline later and map the API output to these widgets.
			</p>
		</section>

		<section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
			<article class="admin-surface rounded-2xl p-5">
				<p class="text-xs font-semibold uppercase tracking-wide admin-muted">Estimated Earnings</p>
				<p class="mt-3 text-3xl font-bold">$0.00</p>
				<p class="mt-1 text-sm admin-muted">Waiting for data source</p>
			</article>
			<article class="admin-surface rounded-2xl p-5">
				<p class="text-xs font-semibold uppercase tracking-wide admin-muted">Page RPM</p>
				<p class="mt-3 text-3xl font-bold">$0.00</p>
				<p class="mt-1 text-sm admin-muted">Revenue per 1,000 views</p>
			</article>
			<article class="admin-surface rounded-2xl p-5">
				<p class="text-xs font-semibold uppercase tracking-wide admin-muted">Impressions</p>
				<p class="mt-3 text-3xl font-bold">0</p>
				<p class="mt-1 text-sm admin-muted">Ad slots rendered</p>
			</article>
			<article class="admin-surface rounded-2xl p-5">
				<p class="text-xs font-semibold uppercase tracking-wide admin-muted">Clicks</p>
				<p class="mt-3 text-3xl font-bold">0</p>
				<p class="mt-1 text-sm admin-muted">Ad click-through events</p>
			</article>
		</section>

		<section class="admin-surface rounded-2xl p-5 sm:p-6">
			<h2 class="text-lg font-bold tracking-tight">Integration Checklist</h2>
			<div class="mt-4 grid gap-3">
				<div class="admin-surface-soft rounded-xl p-4">
					<p class="font-semibold text-sm">1. Connect data source</p>
					<p class="text-sm admin-muted mt-1">Set up a backend fetch from AdSense Reporting API and persist daily metrics.</p>
				</div>
				<div class="admin-surface-soft rounded-xl p-4">
					<p class="font-semibold text-sm">2. Add date filters</p>
					<p class="text-sm admin-muted mt-1">Support 7d, 30d, quarter, and custom ranges for campaign-level insights.</p>
				</div>
				<div class="admin-surface-soft rounded-xl p-4">
					<p class="font-semibold text-sm">3. Segment by page and country</p>
					<p class="text-sm admin-muted mt-1">Track top revenue pages, CTR, and RPM by geography to prioritize content strategy.</p>
				</div>
			</div>
		</section>
	</div>
</AdminLayout>
