---
import AdminLayout from "../../layouts/AdminLayout.astro";
import prisma from "../../lib/prisma";
import { getDashboardStats } from "../../lib/services/dashboard";

// Get user info for welcome message - defensive approach
const user = Astro.locals.user;
const username = user?.username || user?.name || "Admin";

// Fetch dashboard statistics directly
let stats;
try {
	stats = await getDashboardStats();
} catch (error) {
	console.error("Failed to fetch admin stats:", error);
	stats = {
		totalUsers: 0,
		newUsers: 0,
		totalBlogs: 0,
		blogViews: 0,
		totalThreads: 0,
		totalComments: 0,
		pendingModeration: 0,
		recentActivity: [],
		recentBlogs: [],
		weeklyStats: [],
		systemHealth: {
			database: "error",
			uptime: "unknown",
			lastBackup: "unknown",
		},
	};
}

function formatCompactNumber(value: number): string {
	return new Intl.NumberFormat("en-US", {
		notation: "compact",
		maximumFractionDigits: 1,
	}).format(value);
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const rangeDays = 365;
const startDate = new Date(today);
startDate.setDate(startDate.getDate() - (rangeDays - 1));

const calendarStart = new Date(startDate);
const mondayOffset = (calendarStart.getDay() + 6) % 7;
calendarStart.setDate(calendarStart.getDate() - mondayOffset);

const posts = await prisma.blog.findMany({
	where: {
		status: "PUBLISHED",
		OR: [
			{ publishedAt: { gte: calendarStart } },
			{ publishedAt: null, createdAt: { gte: calendarStart } },
		],
	},
	select: {
		publishedAt: true,
		createdAt: true,
	},
});

const postCountByDay = new Map<string, number>();
for (const post of posts) {
	const sourceDate = post.publishedAt ?? post.createdAt;
	const d = new Date(sourceDate);
	d.setHours(0, 0, 0, 0);
	const key = d.toISOString().slice(0, 10);
	postCountByDay.set(key, (postCountByDay.get(key) || 0) + 1);
}

function getHeatLevel(count: number, maxCount: number): number {
	if (count <= 0 || maxCount === 0) return 0;
	const ratio = count / maxCount;
	if (ratio <= 0.25) return 1;
	if (ratio <= 0.5) return 2;
	if (ratio <= 0.75) return 3;
	return 4;
}

type HeatDay = {
	date: Date;
	count: number;
	level: number;
	inRange: boolean;
	label: string;
};

const dayCells: HeatDay[] = [];
let cursor = new Date(calendarStart);

const recentCounts = Array.from(postCountByDay.entries())
	.filter(([key]) => key >= startDate.toISOString().slice(0, 10))
	.map(([, value]) => value);
const maxDailyPosts = recentCounts.length > 0 ? Math.max(...recentCounts) : 0;

while (cursor <= today) {
	const dayKey = cursor.toISOString().slice(0, 10);
	const inRange = cursor >= startDate;
	const count = inRange ? postCountByDay.get(dayKey) || 0 : 0;
	dayCells.push({
		date: new Date(cursor),
		count,
		level: inRange ? getHeatLevel(count, maxDailyPosts) : 0,
		inRange,
		label: new Date(cursor).toLocaleDateString("en-US", {
			month: "short",
			day: "numeric",
			year: "numeric",
		}),
	});
	cursor.setDate(cursor.getDate() + 1);
}

const weeks: HeatDay[][] = [];
for (let i = 0; i < dayCells.length; i += 7) {
	weeks.push(dayCells.slice(i, i + 7));
}

const heatTotalPosts = dayCells
	.filter((day) => day.inRange)
	.reduce((sum, day) => sum + day.count, 0);
const activePostingDays = dayCells.filter((day) => day.inRange && day.count > 0).length;

let currentStreak = 0;
for (let i = dayCells.length - 1; i >= 0; i--) {
	const day = dayCells[i];
	if (!day.inRange) continue;
	if (day.count > 0) {
		currentStreak += 1;
	} else {
		break;
	}
}

let longestStreak = 0;
let runningStreak = 0;
for (const day of dayCells) {
	if (!day.inRange) continue;
	if (day.count > 0) {
		runningStreak += 1;
		longestStreak = Math.max(longestStreak, runningStreak);
	} else {
		runningStreak = 0;
	}
}

function getHeatStyle(level: number, inRange: boolean): string {
	if (!inRange) return "background: transparent; border-color: transparent;";
	if (level === 0) {
		return "background: color-mix(in srgb, var(--admin-surface-soft) 80%, var(--admin-bg)); border-color: color-mix(in srgb, var(--admin-border) 70%, transparent);";
	}
	if (level === 1) {
		return "background: color-mix(in srgb, var(--admin-accent) 25%, var(--admin-surface-soft)); border-color: color-mix(in srgb, var(--admin-accent) 30%, var(--admin-border));";
	}
	if (level === 2) {
		return "background: color-mix(in srgb, var(--admin-accent) 45%, var(--admin-surface-soft)); border-color: color-mix(in srgb, var(--admin-accent) 45%, var(--admin-border));";
	}
	if (level === 3) {
		return "background: color-mix(in srgb, var(--admin-accent) 70%, var(--admin-surface-soft)); border-color: color-mix(in srgb, var(--admin-accent) 65%, var(--admin-border));";
	}
	return "background: linear-gradient(135deg, var(--admin-accent), var(--admin-success)); border-color: color-mix(in srgb, var(--admin-accent) 75%, var(--admin-border));";
}
---

<AdminLayout title="Admin Dashboard">
	<div class="space-y-6">
		<section class="admin-surface rounded-3xl p-5 sm:p-7">
			<p class="text-xs font-semibold uppercase tracking-[0.16em] admin-muted">Admin Workspace</p>
			<div class="mt-2 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
				<div>
					<h1 class="text-2xl sm:text-3xl font-bold tracking-tight">Welcome back, {username}</h1>
					<p class="admin-muted mt-1">Platform overview, publishing momentum, and moderation health in one place.</p>
				</div>
				<div class="flex flex-wrap gap-2">
					<a href="/admin/blogs/create" class="admin-focus-ring rounded-xl px-4 py-2 text-sm font-semibold text-white" style="background: linear-gradient(135deg, #2563eb, #1d4ed8);">New Blog Post</a>
					<a href="/admin/metrics" class="admin-focus-ring rounded-xl px-4 py-2 text-sm font-semibold admin-surface-soft">Open Metrics</a>
				</div>
			</div>
		</section>

		<section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
			<article class="admin-surface rounded-2xl p-5">
				<div class="flex items-start justify-between">
					<p class="text-xs font-semibold uppercase tracking-wide admin-muted">Users</p>
					<div class="h-9 w-9 rounded-xl flex items-center justify-center" style="background: color-mix(in srgb, #3b82f6 15%, var(--admin-surface-soft));">
						<svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
						</svg>
					</div>
				</div>
				<p class="mt-3 text-3xl font-bold">{stats.totalUsers.toLocaleString()}</p>
				<p class="mt-1 text-sm admin-muted">{stats.newUsers > 0 ? `+${stats.newUsers} this week` : "No new users this week"}</p>
			</article>
			<article class="admin-surface rounded-2xl p-5">
				<div class="flex items-start justify-between">
					<p class="text-xs font-semibold uppercase tracking-wide admin-muted">Published Blogs</p>
					<div class="h-9 w-9 rounded-xl flex items-center justify-center" style="background: color-mix(in srgb, #10b981 15%, var(--admin-surface-soft));">
						<svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
						</svg>
					</div>
				</div>
				<p class="mt-3 text-3xl font-bold">{stats.totalBlogs.toLocaleString()}</p>
				<p class="mt-1 text-sm admin-muted">{formatCompactNumber(stats.blogViews)} total views</p>
			</article>
			<article class="admin-surface rounded-2xl p-5">
				<div class="flex items-start justify-between">
					<p class="text-xs font-semibold uppercase tracking-wide admin-muted">Community Threads</p>
					<div class="h-9 w-9 rounded-xl flex items-center justify-center" style="background: color-mix(in srgb, #8b5cf6 15%, var(--admin-surface-soft));">
						<svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path>
						</svg>
					</div>
				</div>
				<p class="mt-3 text-3xl font-bold">{stats.totalThreads.toLocaleString()}</p>
				<p class="mt-1 text-sm admin-muted">{stats.totalComments.toLocaleString()} comments</p>
			</article>
			<article class="admin-surface rounded-2xl p-5">
				<div class="flex items-start justify-between">
					<p class="text-xs font-semibold uppercase tracking-wide admin-muted">Moderation Queue</p>
					<div class="h-9 w-9 rounded-xl flex items-center justify-center" style={`background: color-mix(in srgb, ${stats.pendingModeration > 0 ? '#f97316' : '#10b981'} 15%, var(--admin-surface-soft));`}>
						<svg class={`w-5 h-5 ${stats.pendingModeration > 0 ? 'text-orange-500' : 'text-emerald-500'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
						</svg>
					</div>
				</div>
				<p class="mt-3 text-3xl font-bold">{stats.pendingModeration.toLocaleString()}</p>
				<p class="mt-1 text-sm" style={`color: ${stats.pendingModeration > 0 ? "#f97316" : "var(--admin-success)"}`}>
					{stats.pendingModeration > 0 ? "Needs attention" : "All clear"}
				</p>
			</article>
		</section>

		<section class="admin-surface rounded-2xl p-5 sm:p-6">
			<div class="flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between mb-5">
				<div>
					<h2 class="text-lg sm:text-xl font-bold tracking-tight">Blog Publishing Activity</h2>
					<p class="text-sm admin-muted">GitHub-style activity over the last 12 months.</p>
				</div>
				<p class="text-sm admin-muted">{heatTotalPosts} posts across {activePostingDays} active days</p>
			</div>

			<div class="overflow-x-auto pb-1">
				<div class="min-w-[760px]">
					<div class="flex">
						<div class="w-10 pt-8 pr-2">
							<div class="grid grid-rows-7 gap-1 text-[10px] leading-3 admin-muted">
								<span>Mon</span>
								<span></span>
								<span>Wed</span>
								<span></span>
								<span>Fri</span>
								<span></span>
								<span></span>
							</div>
						</div>
						<div class="flex-1">
							<div class="flex gap-1 text-[10px] admin-muted mb-2 pl-0.5">
								{weeks.map((week) => {
									const first = week.find((day) => day.inRange);
									const dayOfMonth = first ? first.date.getDate() : 99;
									const showLabel = dayOfMonth < 8;
									return <span class="w-3.5 text-center">{showLabel && first ? first.date.toLocaleString("en-US", { month: "short" }) : ""}</span>;
								})}
							</div>
							<div class="flex gap-1">
								{weeks.map((week) => (
									<div class="grid grid-rows-7 gap-1">
										{week.map((day) => (
											<div
												class="h-3.5 w-3.5 rounded-[3px] border"
												style={getHeatStyle(day.level, day.inRange)}
												title={day.inRange ? `${day.count} posts on ${day.label}` : ""}
												aria-label={day.inRange ? `${day.count} posts on ${day.label}` : "Out of range"}
											></div>
										))}
									</div>
								))}
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between text-sm">
				<p class="admin-muted">Current streak: <span class="font-semibold" style="color: var(--admin-text);">{currentStreak} day{currentStreak === 1 ? "" : "s"}</span> | Longest streak: <span class="font-semibold" style="color: var(--admin-text);">{longestStreak} day{longestStreak === 1 ? "" : "s"}</span></p>
				<div class="flex items-center gap-2 admin-muted">
					<span>Less</span>
					<span class="h-3 w-3 rounded-[3px] border" style={getHeatStyle(0, true)}></span>
					<span class="h-3 w-3 rounded-[3px] border" style={getHeatStyle(1, true)}></span>
					<span class="h-3 w-3 rounded-[3px] border" style={getHeatStyle(2, true)}></span>
					<span class="h-3 w-3 rounded-[3px] border" style={getHeatStyle(3, true)}></span>
					<span class="h-3 w-3 rounded-[3px] border" style={getHeatStyle(4, true)}></span>
					<span>More</span>
				</div>
			</div>
		</section>

		<section class="admin-surface rounded-2xl p-5 sm:p-6">
				<h2 class="text-lg font-bold tracking-tight mb-4">Recent Activity</h2>
				{stats.recentActivity && stats.recentActivity.length > 0 ? (
					<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
						{stats.recentActivity.slice(0, 6).map((activity: any) => (
							<div class="admin-surface-soft rounded-xl p-3.5">
								<p class="text-sm font-medium">{activity.description}</p>
								<p class="text-xs admin-muted mt-1">{activity.timestamp}</p>
							</div>
						))}
					</div>
				) : (
					<p class="admin-muted text-sm">No recent activity yet.</p>
				)}
			</section>

		<!-- Weekly Stats Graph & Recent Blog Posts -->
		<section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
			<!-- Weekly Stats Graph -->
			<div class="admin-surface rounded-2xl p-5 sm:p-6">
				<div class="flex items-center justify-between mb-5">
					<div>
						<h2 class="text-lg font-bold tracking-tight">Weekly Overview</h2>
						<p class="text-sm admin-muted">Posts and views for the last 7 days</p>
					</div>
					<div class="flex items-center gap-4 text-xs">
						<div class="flex items-center gap-1.5">
							<span class="h-2.5 w-2.5 rounded-full" style="background: var(--admin-accent);"></span>
							<span class="admin-muted">Posts</span>
						</div>
						<div class="flex items-center gap-1.5">
							<span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
							<span class="admin-muted">Views</span>
						</div>
					</div>
				</div>
				<div class="h-48 flex items-end gap-2">
					{stats.weeklyStats.map((day: any) => {
						const maxPosts = Math.max(...stats.weeklyStats.map((d: any) => d.posts), 1);
						const maxViews = Math.max(...stats.weeklyStats.map((d: any) => d.views), 1);
						const postsHeight = (day.posts / maxPosts) * 100;
						const viewsHeight = (day.views / maxViews) * 100;
						return (
							<div class="flex-1 flex flex-col items-center gap-1">
								<div class="w-full flex gap-0.5 items-end h-36">
									<div class="flex-1 rounded-t-md transition-all duration-300 hover:opacity-80" style={`height: ${Math.max(postsHeight, 4)}%; background: var(--admin-accent);`} title={`${day.posts} posts`}></div>
									<div class="flex-1 rounded-t-md bg-emerald-500 transition-all duration-300 hover:opacity-80" style={`height: ${Math.max(viewsHeight, 4)}%;`} title={`${day.views} views`}></div>
								</div>
								<span class="text-[10px] admin-muted font-medium">{day.day}</span>
							</div>
						);
					})}
				</div>
			</div>

			<!-- Recent Blog Posts -->
			<div class="admin-surface rounded-2xl p-5 sm:p-6">
				<div class="flex items-center justify-between mb-4">
					<div>
						<h2 class="text-lg font-bold tracking-tight">Recent Blog Posts</h2>
						<p class="text-sm admin-muted">Latest content published</p>
					</div>
					<a href="/admin/blogs" class="text-xs font-semibold px-3 py-1.5 rounded-lg admin-surface-soft hover:opacity-80 transition">View All</a>
				</div>
				<div class="space-y-3">
					{stats.recentBlogs && stats.recentBlogs.length > 0 ? (
						stats.recentBlogs.map((blog: any) => (
							<a href={`/admin/blogs/edit/${blog.id}`} class="block admin-surface-soft rounded-xl p-3.5 hover:opacity-90 transition">
								<div class="flex items-start gap-3">
									<div class="flex-shrink-0">
										{blog.authorAvatar ? (
											<img src={blog.authorAvatar} alt={blog.author} class="w-9 h-9 rounded-lg object-cover" />
										) : (
											<div class="w-9 h-9 rounded-lg flex items-center justify-center font-semibold text-sm" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6);">
												{blog.author.charAt(0).toUpperCase()}
											</div>
										)}
									</div>
									<div class="flex-1 min-w-0">
										<div class="flex items-start justify-between gap-2">
											<p class="text-sm font-medium truncate">{blog.title}</p>
											<span class={`flex-shrink-0 text-[10px] font-semibold px-2 py-0.5 rounded-full ${blog.status === 'PUBLISHED' ? 'bg-emerald-500/15 text-emerald-600' : 'bg-amber-500/15 text-amber-600'}`}>
												{blog.status}
											</span>
										</div>
										<div class="flex items-center gap-2 mt-1.5 text-xs admin-muted">
											<span class="font-medium">{blog.author}</span>
											<span>•</span>
											<span>{blog.date}</span>
											<span>•</span>
											<span class="flex items-center gap-1">
												<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
												</svg>
												{blog.views.toLocaleString()}
											</span>
										</div>
									</div>
								</div>
							</a>
						))
					) : (
						<div class="text-center py-8">
							<svg class="w-12 h-12 mx-auto admin-muted opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
							</svg>
							<p class="mt-3 text-sm admin-muted">No blog posts yet</p>
							<a href="/admin/blogs/create" class="mt-2 inline-block text-xs font-semibold px-3 py-1.5 rounded-lg text-white" style="background: var(--admin-accent);">Create First Post</a>
						</div>
					)}
				</div>
			</div>
		</section>
	</div>
</AdminLayout>
