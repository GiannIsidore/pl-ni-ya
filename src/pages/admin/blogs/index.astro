---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getBlogs } from "../../../lib/services/blogs";
import { getAllCategories } from "../../../lib/services/categories";

const page = Number(Astro.url.searchParams.get("page")) || 1;
const limit = 12;
const status = Astro.url.searchParams.get("status") || "all";
const search = Astro.url.searchParams.get("search") || "";
const view = Astro.url.searchParams.get("view") || "table";
const categoryId = Astro.url.searchParams.get("category") || "all";

// Fetch categories for the filter dropdown
const categories: any[] = await getAllCategories();

const { blogs, total, totalPages } = await getBlogs({
	page,
	limit,
	status: status === "all" ? undefined : status,
	search,
	categoryId: categoryId === "all" ? undefined : parseInt(categoryId),
});

// Generate page numbers with ellipsis for industry-standard pagination
function getPageNumbers(current: number, total: number): (number | string)[] {
	const pages: (number | string)[] = [];

	if (total <= 7) {
		// Show all pages if 7 or fewer
		for (let i = 1; i <= total; i++) {
			pages.push(i);
		}
	} else {
		// Always show first page
		pages.push(1);

		if (current > 3) {
			pages.push('...');
		}

		// Show pages around current
		const start = Math.max(2, current - 1);
		const end = Math.min(total - 1, current + 1);

		for (let i = start; i <= end; i++) {
			pages.push(i);
		}

		if (current < total - 2) {
			pages.push('...');
		}

		// Always show last page
		pages.push(total);
	}

	return pages;
}

const pages = getPageNumbers(page, totalPages);
---

<AdminLayout title="Manage Blogs">
	<div class="space-y-6">
		<!-- Header -->
		<div class="admin-surface rounded-3xl p-5 sm:p-7">
			<div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.16em] admin-muted">Content Management</p>
					<h1 class="text-2xl sm:text-3xl font-bold tracking-tight mt-2">All Posts</h1>
					<p class="admin-muted mt-1">Manage, edit, and publish your content</p>
				</div>
				<a
					href="/admin/blogs/create"
					class="admin-focus-ring rounded-xl px-4 py-2.5 text-sm font-semibold text-white inline-flex items-center gap-2 transition-all hover:opacity-90"
					style="background: linear-gradient(135deg, #2563eb, #1d4ed8);"
				>
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
					</svg>
					<span>Create New Post</span>
				</a>
			</div>
		</div>

		<!-- Filters & Controls - Industry Standard Search Bar -->
		<div class="admin-surface rounded-2xl p-4 sm:p-5">
			<div class="flex flex-col lg:flex-row gap-4 items-stretch lg:items-center justify-between">
				<!-- Search & Filter Form -->
				<form class="flex flex-1 w-full lg:w-auto flex-col sm:flex-row gap-3 items-stretch sm:items-center" method="get">
					<input type="hidden" name="view" value={view} />

					<!-- Search Input with Icon - Industry Standard -->
					<div class="relative flex-1 max-w-md">
						<div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
							<svg class="h-5 w-5 admin-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
							</svg>
						</div>
						<input
							type="text"
							name="search"
							value={search}
							placeholder="Search posts by title..."
							class="w-full pl-11 pr-4 py-2.5 rounded-xl text-sm admin-surface-soft border admin-focus-ring transition-colors"
							style="border-color: var(--admin-border);"
						/>
						{search && (
							<a
								href={`?page=1&status=${status}&search=&category=${categoryId}&view=${view}`}
								class="absolute inset-y-0 right-0 pr-3 flex items-center hover:opacity-70 transition"
								title="Clear search"
							>
								<svg class="h-4 w-4 admin-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
								</svg>
							</a>
						)}
					</div>

					<!-- Filter Controls -->
					<div class="flex flex-wrap gap-3 items-center">
						<!-- Status Filter -->
						<select
							name="status"
							onchange="this.form.submit()"
							class="px-3 py-2.5 rounded-xl text-sm admin-surface-soft border admin-focus-ring transition-colors cursor-pointer"
							style="border-color: var(--admin-border);"
						>
							<option value="all" selected={status === "all"}>All Status</option>
							<option value="published" selected={status === "published"}>Published</option>
							<option value="draft" selected={status === "draft"}>Draft</option>
							<option value="archived" selected={status === "archived"}>Archived</option>
						</select>

						<!-- Category Filter -->
						<select
							name="category"
							onchange="this.form.submit()"
							class="px-3 py-2.5 rounded-xl text-sm admin-surface-soft border admin-focus-ring transition-colors cursor-pointer"
							style="border-color: var(--admin-border);"
						>
							<option value="all" selected={categoryId === "all"}>All Categories</option>
							{categories.map((cat: any) => (
								<option value={cat.id} selected={categoryId === cat.id.toString()}>
									{cat.name}
								</option>
							))}
						</select>

						<!-- Search Button -->
						<button
							type="submit"
							class="px-4 py-2.5 rounded-xl text-sm font-semibold text-white admin-focus-ring transition-all hover:opacity-90"
							style="background: var(--admin-accent);"
						>
							Search
						</button>
					</div>
				</form>

				<!-- View Toggle - Industry Standard -->
				<div class="flex items-center gap-1 p-1 rounded-xl admin-surface-soft" style="border: 1px solid var(--admin-border);">
					<a
						href={`?page=${page}&status=${status}&search=${search}&category=${categoryId}&view=table`}
						class={`flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-all ${
							view === "table"
								? "admin-surface shadow-sm"
								: "hover:opacity-70"
						}`}
						title="List View"
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
						</svg>
						<span class="hidden sm:inline">List</span>
					</a>
					<a
						href={`?page=${page}&status=${status}&search=${search}&category=${categoryId}&view=card`}
						class={`flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-all ${
							view === "card"
								? "admin-surface shadow-sm"
								: "hover:opacity-70"
						}`}
						title="Card View"
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
						</svg>
						<span class="hidden sm:inline">Cards</span>
					</a>
				</div>
			</div>

			<!-- Active Filters Display -->
			{(search || status !== "all" || categoryId !== "all") && (
				<div class="flex flex-wrap items-center gap-2 mt-4 pt-4" style="border-top: 1px solid var(--admin-border);">
					<span class="text-xs font-medium admin-muted">Active filters:</span>
					{search && (
						<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium" style="background: color-mix(in srgb, var(--admin-accent) 15%, var(--admin-surface-soft)); color: var(--admin-accent);">
							Search: "{search}"
							<a href={`?page=1&status=${status}&search=&category=${categoryId}&view=${view}`} class="hover:opacity-70">×</a>
						</span>
					)}
					{status !== "all" && (
						<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium" style="background: color-mix(in srgb, var(--admin-accent) 15%, var(--admin-surface-soft)); color: var(--admin-accent);">
							Status: {status}
							<a href={`?page=1&status=all&search=${search}&category=${categoryId}&view=${view}`} class="hover:opacity-70">×</a>
						</span>
					)}
					{categoryId !== "all" && (
						<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium" style="background: color-mix(in srgb, var(--admin-accent) 15%, var(--admin-surface-soft)); color: var(--admin-accent);">
							Category: {categories.find((c: any) => c.id.toString() === categoryId)?.name || "Unknown"}
							<a href={`?page=1&status=${status}&search=${search}&category=all&view=${view}`} class="hover:opacity-70">×</a>
						</span>
					)}
					<a href="?view=table" class="text-xs font-medium hover:opacity-70 transition" style="color: var(--admin-accent);">
						Clear all
					</a>
				</div>
			)}
		</div>

		<!-- Content -->
		{
			blogs.length === 0 ? (
				<div class="admin-surface rounded-2xl p-8 sm:p-12 text-center">
					<div class="w-16 h-16 rounded-2xl mx-auto flex items-center justify-center mb-4" style="background: color-mix(in srgb, var(--admin-accent) 15%, var(--admin-surface-soft));">
						<svg class="w-8 h-8" style="color: var(--admin-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
						</svg>
					</div>
					<h3 class="text-lg font-bold">No posts found</h3>
					<p class="admin-muted mb-4 mt-1">Try adjusting your search or filters, or create a new post.</p>
					<a href="/admin/blogs/create" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white admin-focus-ring transition-all hover:opacity-90" style="background: var(--admin-accent);">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
						</svg>
						Create Post
					</a>
				</div>
			) : view === "table" ? (
				// Table View - Same color as dashboard cards
				<div class="admin-surface rounded-2xl overflow-hidden">
					<div class="overflow-x-auto">
						<table class="w-full">
							<thead>
								<tr class="admin-surface-soft">
									<th class="text-left px-5 py-4 text-xs font-semibold uppercase tracking-wider admin-muted">Post</th>
									<th class="text-left px-5 py-4 text-xs font-semibold uppercase tracking-wider admin-muted">Author</th>
									<th class="text-left px-5 py-4 text-xs font-semibold uppercase tracking-wider admin-muted">Status</th>
									<th class="text-left px-5 py-4 text-xs font-semibold uppercase tracking-wider admin-muted">Date</th>
									<th class="text-right px-5 py-4 text-xs font-semibold uppercase tracking-wider admin-muted">Actions</th>
								</tr>
							</thead>
							<tbody>
								{blogs.map((blog, index) => (
									<tr class="transition-colors hover:opacity-90" style={`border-top: 1px solid var(--admin-border);${index === 0 ? 'border-top: none;' : ''}`}>
										<td class="px-5 py-4">
											<div class="flex items-center gap-3">
												{blog.image_blog_featuredImageIdToimage ? (
													<img
														src={blog.image_blog_featuredImageIdToimage.url}
														alt={blog.title}
														class="w-12 h-12 rounded-xl object-cover flex-shrink-0"
													/>
												) : (
													<div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: color-mix(in srgb, var(--admin-accent) 15%, var(--admin-surface-soft));">
														<svg class="w-6 h-6" style="color: var(--admin-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
															<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
														</svg>
													</div>
												)}
												<div class="min-w-0">
													<p class="font-semibold truncate max-w-[200px]">{blog.title}</p>
													<p class="text-xs admin-muted truncate max-w-[200px] mt-0.5">
														{blog.excerpt || "No description..."}
													</p>
												</div>
											</div>
										</td>
										<td class="px-5 py-4">
											<div class="flex items-center gap-2">
												{blog.user?.avatar ? (
													<img
														src={blog.user.avatar}
														alt={blog.user.username || "User"}
														class="w-8 h-8 rounded-full object-cover"
													/>
												) : (
													<div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold text-white" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6);">
														{(blog.user?.username || "U").charAt(0).toUpperCase()}
													</div>
												)}
												<span class="text-sm font-medium">{blog.user?.username || "Unknown"}</span>
											</div>
										</td>
										<td class="px-5 py-4">
											<span class={`inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold`}
												style={blog.status === "PUBLISHED" ? "background: color-mix(in srgb, var(--admin-success) 15%, transparent); color: var(--admin-success);" : blog.status === "DRAFT" ? "background: color-mix(in srgb, var(--admin-muted) 15%, transparent); color: var(--admin-muted);" : "background: color-mix(in srgb, #f59e0b 15%, transparent); color: #f59e0b;"}>
												{blog.status}
											</span>
										</td>
										<td class="px-5 py-4">
											<div class="text-sm font-medium">
												{new Date(blog.createdAt).toLocaleDateString(undefined, {
													month: "short",
													day: "numeric",
													year: "numeric",
												})}
											</div>
											<div class="text-xs admin-muted">
												{new Date(blog.createdAt).toLocaleTimeString(undefined, {
													hour: "2-digit",
													minute: "2-digit",
												})}
											</div>
										</td>
										<td class="px-5 py-4 text-right">
											<div class="flex items-center justify-end gap-1">
												<a
													href={`/admin/blogs/edit/${blog.id}`}
													class="h-9 w-9 rounded-xl flex items-center justify-center admin-surface-soft hover:opacity-80 transition admin-focus-ring"
													title="Edit Post"
												>
													<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
														<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
													</svg>
												</a>
												<button
													type="button"
													data-id={blog.id}
													data-title={blog.title}
													class="delete-btn h-9 w-9 rounded-xl flex items-center justify-center admin-surface-soft hover:opacity-80 transition admin-focus-ring"
													style="color: #ef4444;"
													title="Delete Post"
												>
													<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
														<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
													</svg>
												</button>
											</div>
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					<!-- Table Footer with Pagination Info -->
					<div class="flex flex-col sm:flex-row items-center justify-between px-5 py-4 admin-surface-soft gap-3" style="border-top: 1px solid var(--admin-border);">
						<p class="text-sm admin-muted">
							Showing <span class="font-semibold" style="color: var(--admin-text);">{(page - 1) * limit + 1}</span> to{" "}
							<span class="font-semibold" style="color: var(--admin-text);">{Math.min(page * limit, total)}</span> of{" "}
							<span class="font-semibold" style="color: var(--admin-text);">{total}</span> results
						</p>
						{totalPages > 1 && (
							<div class="flex items-center gap-2">
								{page > 1 && (
									<a
										href={`?page=${page - 1}&status=${status}&search=${search}&category=${categoryId}&view=${view}`}
										class="px-3 py-2 rounded-xl text-sm font-medium admin-surface hover:opacity-80 transition admin-focus-ring"
										style="border: 1px solid var(--admin-border);"
									>
										Previous
									</a>
								)}
								<div class="flex items-center gap-1">
									{pages.map((p) => {
										if (p === '...') {
											return (
												<span class="px-3 py-2 text-sm admin-muted">...</span>
											);
										}
										return (
											<a
												href={`?page=${p}&status=${status}&search=${search}&category=${categoryId}&view=${view}`}
												class={`px-3 py-2 rounded-xl text-sm font-medium admin-focus-ring transition ${
													p === page
														? "text-white"
														: "admin-surface hover:opacity-80"
												}`}
												style={p === page ? "background: var(--admin-accent);" : "border: 1px solid var(--admin-border);"}
											>
												{p}
											</a>
										);
									})}
								</div>
								{page < totalPages && (
									<a
										href={`?page=${page + 1}&status=${status}&search=${search}&category=${categoryId}&view=${view}`}
										class="px-3 py-2 rounded-xl text-sm font-medium admin-surface hover:opacity-80 transition admin-focus-ring"
										style="border: 1px solid var(--admin-border);"
									>
										Next
									</a>
								)}
							</div>
						)}
					</div>
				</div>
			) : (
				// Card View - Same color as dashboard cards
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
					{blogs.map((blog) => (
						<div class="admin-surface rounded-2xl overflow-hidden transition-all hover:shadow-lg" style="border: 1px solid var(--admin-border);">
							<div class="relative h-40 admin-surface-soft">
								{blog.image_blog_featuredImageIdToimage ? (
									<img
										src={blog.image_blog_featuredImageIdToimage.url}
										alt={blog.title}
										class="w-full h-full object-cover"
									/>
								) : (
									<div class="w-full h-full flex items-center justify-center">
										<svg class="w-12 h-12 admin-muted opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
										</svg>
									</div>
								)}
								<div class="absolute top-3 right-3">
									<span class={`inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold`} style={blog.status === "PUBLISHED" ? "background: color-mix(in srgb, var(--admin-success) 15%, transparent); color: var(--admin-success);" : blog.status === "DRAFT" ? "background: color-mix(in srgb, var(--admin-muted) 15%, transparent); color: var(--admin-muted);" : "background: color-mix(in srgb, #f59e0b 15%, transparent); color: #f59e0b;"}>
										{blog.status}
									</span>
								</div>
							</div>
							<div class="p-4">
								<h3 class="font-semibold line-clamp-1">{blog.title}</h3>
								<p class="text-sm admin-muted line-clamp-2 mt-1 mb-3">{blog.excerpt || "No excerpt available."}</p>
								<div class="flex items-center justify-between pt-3" style="border-top: 1px solid var(--admin-border);">
									<span class="text-xs admin-muted">
										{new Date(blog.createdAt).toLocaleDateString()}
									</span>
									<div class="flex gap-1">
										<a
											href={`/admin/blogs/edit/${blog.id}`}
											class="h-8 w-8 rounded-lg flex items-center justify-center admin-surface-soft hover:opacity-80 transition admin-focus-ring"
										>
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
											</svg>
										</a>
										<button
											type="button"
											data-id={blog.id}
											data-title={blog.title}
											class="delete-btn h-8 w-8 rounded-lg flex items-center justify-center admin-surface-soft hover:opacity-80 transition admin-focus-ring"
											style="color: #ef4444;"
										>
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
											</svg>
										</button>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			)
		}

		<!-- Pagination for Card View -->
		{
			totalPages > 1 && view === "card" && (
				<div class="admin-surface rounded-2xl p-4 flex flex-col sm:flex-row items-center justify-between gap-3">
					<p class="text-sm admin-muted">
						Showing <span class="font-semibold" style="color: var(--admin-text);">{(page - 1) * limit + 1}</span> to{" "}
						<span class="font-semibold" style="color: var(--admin-text);">{Math.min(page * limit, total)}</span> of{" "}
						<span class="font-semibold" style="color: var(--admin-text);">{total}</span> results
					</p>
					<div class="flex items-center gap-2">
						{page > 1 && (
							<a
								href={`?page=${page - 1}&status=${status}&search=${search}&category=${categoryId}&view=${view}`}
								class="px-3 py-2 rounded-xl text-sm font-medium admin-surface hover:opacity-80 transition admin-focus-ring"
								style="border: 1px solid var(--admin-border);"
							>
								Previous
							</a>
						)}
						<div class="flex items-center gap-1">
							{pages.map((p) => {
								if (p === '...') {
									return (
										<span class="px-3 py-2 text-sm admin-muted">...</span>
									);
								}
								return (
									<a
										href={`?page=${p}&status=${status}&search=${search}&category=${categoryId}&view=${view}`}
										class={`px-3 py-2 rounded-xl text-sm font-medium admin-focus-ring transition ${
											p === page
												? "text-white"
												: "admin-surface hover:opacity-80"
										}`}
										style={p === page ? "background: var(--admin-accent);" : "border: 1px solid var(--admin-border);"}
									>
										{p}
									</a>
								);
							})}
						</div>
						{page < totalPages && (
							<a
								href={`?page=${page + 1}&status=${status}&search=${search}&category=${categoryId}&view=${view}`}
								class="px-3 py-2 rounded-xl text-sm font-medium admin-surface hover:opacity-80 transition admin-focus-ring"
								style="border: 1px solid var(--admin-border);"
							>
								Next
							</a>
						)}
					</div>
				</div>
			)
		}
	</div>

	<!-- Delete Confirmation Modal - Admin Styled -->
	<div id="delete-modal" class="fixed inset-0 z-50 hidden">
		<!-- Backdrop -->
		<div class="absolute inset-0 bg-black/50" id="delete-modal-backdrop"></div>

		<!-- Modal -->
		<div class="absolute inset-0 flex items-center justify-center p-4">
			<div class="admin-surface rounded-2xl w-full max-w-md p-6 shadow-2xl" style="border: 1px solid var(--admin-border);">
				<div class="flex items-center gap-3 mb-4">
					<div class="h-10 w-10 rounded-xl flex items-center justify-center" style="background: color-mix(in srgb, #ef4444 15%, var(--admin-surface-soft));">
						<svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold">Confirm Delete</h3>
				</div>
				<p class="admin-muted mb-6">
					Are you sure you want to delete <span id="delete-target-title" class="font-semibold" style="color: var(--admin-text);"></span>? This action cannot be undone.
				</p>
				<div class="flex items-center justify-end gap-3">
					<button id="cancel-delete" class="px-4 py-2.5 rounded-xl text-sm font-semibold admin-surface-soft hover:opacity-80 transition admin-focus-ring" style="border: 1px solid var(--admin-border);">
						Cancel
					</button>
					<button id="confirm-delete" class="px-4 py-2.5 rounded-xl text-sm font-semibold text-white hover:opacity-90 transition admin-focus-ring" style="background: #ef4444;">
						Delete
					</button>
				</div>
			</div>
		</div>
	</div>
</AdminLayout>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const deleteButtons = document.querySelectorAll(".delete-btn");
		const modal = document.getElementById("delete-modal");
		const modalBackdrop = document.getElementById("delete-modal-backdrop");
		const cancelBtn = document.getElementById("cancel-delete");
		const confirmBtn = document.getElementById("confirm-delete");
		const targetTitleSpan = document.getElementById("delete-target-title");
		let deleteId: string | null = null;

		function openModal() {
			if (modal) {
				modal.classList.remove("hidden");
				document.body.style.overflow = "hidden";
			}
		}

		function closeModal() {
			if (modal) {
				modal.classList.add("hidden");
				document.body.style.overflow = "";
			}
			deleteId = null;
		}

		deleteButtons.forEach((btn) => {
			btn.addEventListener("click", () => {
				deleteId = btn.getAttribute("data-id");
				const title = btn.getAttribute("data-title");
				if (targetTitleSpan) targetTitleSpan.textContent = `"${title}"`;
				openModal();
			});
		});

		cancelBtn?.addEventListener("click", closeModal);
		modalBackdrop?.addEventListener("click", closeModal);

		// Close on escape key
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && !modal?.classList.contains("hidden")) {
				closeModal();
			}
		});

		confirmBtn?.addEventListener("click", async () => {
			if (!deleteId) return;

			const originalText = confirmBtn.textContent;
			confirmBtn.textContent = "Deleting...";
			confirmBtn.setAttribute("disabled", "true");

			try {
				const response = await fetch(`/api/admin/blogs/${deleteId}`, {
					method: "DELETE",
				});

				if (response.ok) {
					window.location.reload();
				} else {
					alert("Failed to delete blog post");
					confirmBtn.textContent = "Delete";
					confirmBtn.removeAttribute("disabled");
				}
			} catch (error) {
				console.error("Error:", error);
				alert("An error occurred");
				confirmBtn.textContent = "Delete";
				confirmBtn.removeAttribute("disabled");
			}
		});
	});
</script>
