---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Admin Dashboard - Project Likha" } = Astro.props;

// Get user info - defensive approach
const user = Astro.locals.user;

// Check if user has admin or moderator role
const hasAdminAccess = user?.role === "ADMIN" || user?.role === "MODERATOR";

if (!hasAdminAccess) {
	return Astro.redirect("/login");
}

import AdminSidebar from "../components/AdminSidebar.astro";
---

<!doctype html>
<html lang="en" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/Char.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<script is:inline>
			const savedTheme = localStorage.getItem("admin-theme");
			if (savedTheme === "dark" || savedTheme === "light") {
				document.documentElement.setAttribute("data-theme", savedTheme);
			}
		</script>
	</head>
	<body class="admin-app-bg min-h-screen antialiased">
		<div class="flex h-screen overflow-hidden">
			<!-- Admin Sidebar -->
			<AdminSidebar user={user} />

			<!-- Main Content -->
			<div class="flex-1 flex flex-col min-h-0 border-l" style="border-color: var(--admin-border);">
				<!-- Page Content -->
				<main class="flex-1 overflow-auto p-4 sm:p-6 lg:p-8">
					<slot />
				</main>
			</div>
		</div>

		<!-- System Health Status Floating Button -->
		<div id="health-status-wrapper" class="fixed bottom-6 right-6 z-40">
			<button
				id="health-status-btn"
				type="button"
				class="group h-14 w-14 rounded-2xl admin-surface shadow-lg border flex items-center justify-center transition-all duration-300 hover:scale-105 hover:shadow-xl admin-focus-ring"
				style="border-color: var(--admin-border);"
				aria-label="System Health Status"
			>
				<svg class="w-6 h-6 transition-transform duration-300 group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
				</svg>
				<!-- Status indicator dot -->
				<span id="health-indicator-dot" class="absolute -top-1 -right-1 h-4 w-4 rounded-full border-2 animate-pulse" style="background: var(--admin-success); border-color: var(--admin-surface);"></span>
			</button>
		</div>

		<!-- System Health Status Drawer Overlay -->
		<div id="health-drawer-overlay" class="fixed inset-0 bg-black/50 z-50 opacity-0 pointer-events-none transition-opacity duration-300"></div>

		<!-- System Health Status Drawer -->
		<aside
			id="health-drawer"
			class="fixed top-0 right-0 h-full w-full sm:w-96 admin-surface shadow-2xl z-50 transform translate-x-full transition-transform duration-300 ease-out flex flex-col"
			style="border-left: 1px solid var(--admin-border);"
		>
			<!-- Drawer Header -->
			<div class="px-6 py-5 border-b flex items-center justify-between" style="border-color: var(--admin-border);">
				<div class="flex items-center gap-3">
					<div class="h-10 w-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #10b981, #059669);">
						<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
					</div>
					<div>
						<h2 class="text-lg font-bold tracking-tight">System Health</h2>
						<p class="text-xs admin-muted">Real-time status monitoring</p>
					</div>
				</div>
				<button
					id="health-drawer-close"
					type="button"
					class="h-9 w-9 rounded-xl admin-surface-soft flex items-center justify-center hover:opacity-80 transition admin-focus-ring"
					aria-label="Close drawer"
				>
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</div>

			<!-- Drawer Content -->
			<div class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar">
				<!-- Overall Status -->
				<div class="admin-surface-soft rounded-2xl p-4 text-center">
					<div id="overall-status-icon" class="h-16 w-16 rounded-2xl mx-auto flex items-center justify-center mb-3" style="background: linear-gradient(135deg, #10b981, #059669);">
						<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
						</svg>
					</div>
					<p id="overall-status-text" class="text-lg font-bold" style="color: var(--admin-success);">All Systems Operational</p>
					<p class="text-xs admin-muted mt-1">Last checked: <span id="last-checked-time">Just now</span></p>
				</div>

				<!-- Status Items -->
				<div class="space-y-3">
					<h3 class="text-xs font-bold uppercase tracking-wider admin-muted px-1">Services</h3>

					<!-- Database Status -->
					<div class="admin-surface-soft rounded-xl p-4">
						<div class="flex items-center justify-between">
							<div class="flex items-center gap-3">
								<div class="h-9 w-9 rounded-lg flex items-center justify-center" style="background: color-mix(in srgb, var(--admin-accent) 15%, var(--admin-surface));">
									<svg class="w-5 h-5" style="color: var(--admin-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
									</svg>
								</div>
								<div>
									<p class="text-sm font-semibold">Database</p>
									<p class="text-xs admin-muted">PostgreSQL</p>
								</div>
							</div>
							<span id="db-status" class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background: color-mix(in srgb, var(--admin-success) 15%, transparent); color: var(--admin-success);">Healthy</span>
						</div>
					</div>

					<!-- Server Uptime -->
					<div class="admin-surface-soft rounded-xl p-4">
						<div class="flex items-center justify-between">
							<div class="flex items-center gap-3">
								<div class="h-9 w-9 rounded-lg flex items-center justify-center" style="background: color-mix(in srgb, #3b82f6 15%, var(--admin-surface));">
									<svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
									</svg>
								</div>
								<div>
									<p class="text-sm font-semibold">Server Uptime</p>
									<p class="text-xs admin-muted">Application server</p>
								</div>
							</div>
							<span id="uptime-status" class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background: color-mix(in srgb, var(--admin-success) 15%, transparent); color: var(--admin-success);">99.9%</span>
						</div>
					</div>

					<!-- Last Backup -->
					<div class="admin-surface-soft rounded-xl p-4">
						<div class="flex items-center justify-between">
							<div class="flex items-center gap-3">
								<div class="h-9 w-9 rounded-lg flex items-center justify-center" style="background: color-mix(in srgb, #8b5cf6 15%, var(--admin-surface));">
									<svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
									</svg>
								</div>
								<div>
									<p class="text-sm font-semibold">Last Backup</p>
									<p class="text-xs admin-muted">Automated backup</p>
								</div>
							</div>
							<span id="backup-status" class="text-xs font-semibold admin-muted">2 hours ago</span>
						</div>
					</div>

					<!-- Memory Usage -->
					<div class="admin-surface-soft rounded-xl p-4">
						<div class="flex items-center justify-between mb-3">
							<div class="flex items-center gap-3">
								<div class="h-9 w-9 rounded-lg flex items-center justify-center" style="background: color-mix(in srgb, #f59e0b 15%, var(--admin-surface));">
									<svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
									</svg>
								</div>
								<div>
									<p class="text-sm font-semibold">Memory Usage</p>
									<p class="text-xs admin-muted">System resources</p>
								</div>
							</div>
							<span class="text-xs font-semibold" style="color: var(--admin-success);">42%</span>
						</div>
						<div class="h-2 rounded-full overflow-hidden" style="background: var(--admin-border);">
							<div class="h-full rounded-full transition-all duration-500" style="width: 42%; background: linear-gradient(90deg, #10b981, #059669);"></div>
						</div>
					</div>

					<!-- CPU Usage -->
					<div class="admin-surface-soft rounded-xl p-4">
						<div class="flex items-center justify-between mb-3">
							<div class="flex items-center gap-3">
								<div class="h-9 w-9 rounded-lg flex items-center justify-center" style="background: color-mix(in srgb, #ec4899 15%, var(--admin-surface));">
									<svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
									</svg>
								</div>
								<div>
									<p class="text-sm font-semibold">CPU Usage</p>
									<p class="text-xs admin-muted">Processing load</p>
								</div>
							</div>
							<span class="text-xs font-semibold" style="color: var(--admin-success);">28%</span>
						</div>
						<div class="h-2 rounded-full overflow-hidden" style="background: var(--admin-border);">
							<div class="h-full rounded-full transition-all duration-500" style="width: 28%; background: linear-gradient(90deg, #10b981, #059669);"></div>
						</div>
					</div>
				</div>

				<!-- Quick Actions -->
				<div class="space-y-3 pt-2">
					<h3 class="text-xs font-bold uppercase tracking-wider admin-muted px-1">Quick Actions</h3>
					<button
						id="refresh-health-btn"
						type="button"
						class="w-full admin-surface-soft rounded-xl px-4 py-3 text-sm font-semibold flex items-center justify-center gap-2 hover:opacity-90 transition admin-focus-ring"
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
						</svg>
						Refresh Status
					</button>
				</div>
			</div>

			<!-- Drawer Footer -->
			<div class="px-6 py-4 border-t" style="border-color: var(--admin-border);">
				<p class="text-xs text-center admin-muted">
					Monitoring powered by Project Likha
				</p>
			</div>
		</aside>
	</body>
</html>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		// Health Status Drawer elements
		const healthBtn = document.getElementById("health-status-btn");
		const healthDrawer = document.getElementById("health-drawer");
		const healthOverlay = document.getElementById("health-drawer-overlay");
		const healthCloseBtn = document.getElementById("health-drawer-close");
		const refreshHealthBtn = document.getElementById("refresh-health-btn");

		// Health Status Drawer functionality
		function openHealthDrawer() {
			if (healthDrawer && healthOverlay) {
				healthDrawer.classList.remove("translate-x-full");
				healthOverlay.classList.remove("opacity-0", "pointer-events-none");
				document.body.style.overflow = "hidden";
			}
		}

		function closeHealthDrawer() {
			if (healthDrawer && healthOverlay) {
				healthDrawer.classList.add("translate-x-full");
				healthOverlay.classList.add("opacity-0", "pointer-events-none");
				document.body.style.overflow = "";
			}
		}

		if (healthBtn) {
			healthBtn.addEventListener("click", openHealthDrawer);
		}

		if (healthCloseBtn) {
			healthCloseBtn.addEventListener("click", closeHealthDrawer);
		}

		if (healthOverlay) {
			healthOverlay.addEventListener("click", closeHealthDrawer);
		}

		// Close drawer on escape key
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape") {
				closeHealthDrawer();
			}
		});

		// Refresh health status
		if (refreshHealthBtn) {
			refreshHealthBtn.addEventListener("click", async () => {
				const lastCheckedEl = document.getElementById("last-checked-time");
				if (lastCheckedEl) {
					lastCheckedEl.textContent = "Refreshing...";
				}

				// Simulate API call
				await new Promise(resolve => setTimeout(resolve, 1000));

				if (lastCheckedEl) {
					lastCheckedEl.textContent = "Just now";
				}
			});
		}
	});
</script>

<style>
	.custom-scrollbar::-webkit-scrollbar {
		width: 6px;
	}
	.custom-scrollbar::-webkit-scrollbar-track {
		background: transparent;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: hsl(var(--bc) / 0.3);
		border-radius: 3px;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb:hover {
		background: hsl(var(--bc) / 0.5);
	}
</style>
