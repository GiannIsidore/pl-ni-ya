---
import { Image } from "astro:assets";
import char from "../assets/Char.svg";
import { cn } from "../lib/utils";
---

<section
  class={cn(
    "w-full",
    "text-white px-6 lg:px-12 pt-28 lg:pt-32 pb-0 relative",
    "bg-neutral-900",
    "flex items-end",
    "overflow-hidden",
  )}
>
  <div
    class="max-w-7xl mx-auto w-full flex flex-col lg:flex-row items-end justify-between gap-8 lg:gap-12"
  >
    <div class="flex-1 space-y-6 pb-12 lg:pb-16">
      <h1
        class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl"
        style="font-family: 'Bebas Neue', sans-serif; font-weight: 400; font-style: normal; letter-spacing: -0.04em; line-height: 0.85;"
      >
        WELCOME TO<br />PROJECT LIKHA
      </h1>
      <p class="text-lg lg:text-xl text-gray-300 max-w-md">
        A community for tech enthusiasts and programmers.
      </p>
      <a
        href="/blogs"
        class="inline-block bg-white text-black rounded-md py-3 px-6 hover:bg-gray-100 transition-colors font-medium"
      >
        Explore now
      </a>
    </div>
    <div class="flex-1 flex justify-center lg:justify-end items-end relative z-10">
      <Image
        src={char}
        alt="Character illustration"
        width={524}
        height={684}
        class="w-[300px] sm:w-[400px] lg:w-[450px] xl:w-[524px] h-auto object-contain translate-y-8"
      />
    </div>
  </div>
</section>
