---
import { Image } from "astro:assets";
import logo from "../assets/logo2.svg";

interface Props {
	user: any;
}

const { user } = Astro.props;
const username = user?.username || user?.name || "Admin";

// Role-based menu visibility - defensive approach
const isAdmin = user?.role === "ADMIN";
const isModerator = user?.role === "MODERATOR";
const canAccessSettings = isAdmin;
const canManageRoles = isAdmin;
---

<aside
	id="admin-sidebar"
	class="w-64 admin-surface flex flex-col h-screen lg:translate-x-0 -translate-x-full transition-transform duration-200 fixed lg:relative z-50 flex-shrink-0 shadow-xl lg:shadow-none"
>
	<!-- Logo/Brand -->
	<div class="px-5 py-4">
		<div class="flex items-center gap-3">
     <Image
          src={logo}
          alt="Project Likha Logo"
          width={100}
          height={100}
          class="w-32 h-8"
        />

		</div>
	</div>

	<!-- Navigation -->
	<nav class="flex-1 overflow-y-auto px-3 py-4 space-y-4 custom-scrollbar">
		<!-- General -->
		<div class="space-y-0.5">
			<div class="px-3 text-xs font-bold text-base-content/50 uppercase tracking-wider mb-2">
				General
			</div>
			<a
				href="/admin"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">Dashboard</span>
			</a>
		</div>

		<!-- Blog Management -->
		<div class="space-y-0.5">
			<div class="px-3 text-xs font-bold text-base-content/50 uppercase tracking-wider mb-2">
				Content
			</div>
			<a
				href="/admin/blogs"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">Blog Posts</span>
			</a>
			<a
				href="/admin/blogs/create"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M12 4v16m8-8H4"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">New Post</span>
			</a>
			<a
				href="/admin/categories"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">Categories</span>
			</a>
		</div>

		<!-- Forum Management -->
		<div class="space-y-0.5">
			<div class="px-3 text-xs font-bold text-base-content/50 uppercase tracking-wider mb-2">
				Community
			</div>
			<a
				href="/admin/forums"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">Forums</span>
			</a>
			<a
				href="/admin/threads"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">Threads</span>
			</a>
			<a
				href="/admin/reports"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">Reports</span>
			</a>
		</div>

		<!-- User Management -->
		<div class="space-y-0.5">
			<div class="px-3 text-xs font-bold text-base-content/50 uppercase tracking-wider mb-2">
				Users
			</div>
			<a
				href="/admin/users"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">All Users</span>
			</a>
			{
				canManageRoles && (
					<a
						href="/admin/users/roles"
						class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
					>
						<svg
							class="w-5 h-5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826 3.31 2.37 2.37.996.608 2.296.07 2.572-1.065z"
							/>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
							/>
						</svg>
						<span class="font-medium text-sm leading-tight">Roles</span>
					</a>
				)
			}
		</div>

		<!-- Insights -->
		<div class="space-y-0.5">
			<div class="px-3 text-xs font-bold text-base-content/50 uppercase tracking-wider mb-2">
				Insights
			</div>
			<a
				href="/admin/metrics"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M11 3v18M4 8h7M4 16h7m2-10h7m-7 8h7"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">Metrics (AdSense)</span>
			</a>
		</div>

		<!-- System -->
		<div class="space-y-0.5">
			<div class="px-3 text-xs font-bold text-base-content/50 uppercase tracking-wider mb-2">
				System
			</div>
			<a
				href="/admin/audit-logs"
				class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
					></path>
				</svg>
				<span class="font-medium text-sm leading-tight">Audit Logs</span>
			</a>
			{
				canAccessSettings && (
					<a
						href="/admin/settings"
						class="admin-nav-item group flex items-center gap-3 px-3 py-2.5 rounded-xl admin-muted hover:bg-[var(--admin-surface-soft)] hover:text-[var(--admin-text)] transition-all duration-200"
					>
						<svg
							class="w-5 h-5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826 3.31 2.37 2.37.996.608 2.296.07 2.572-1.065z"
							/>
						</svg>
						<span class="font-medium text-sm leading-tight">Settings</span>
					</a>
				)
			}
		</div>
	</nav>

	<!-- User Card at Bottom -->
	<div class="px-3 py-4 border-t" style="border-color: var(--admin-border);">
		<div class="flex items-center gap-3 px-3 py-2.5 rounded-xl admin-surface-soft">
			{
				user?.avatar ? (
					<img
						src={user.avatar}
						alt={user.username || user.name || "User"}
						class="w-9 h-9 rounded-lg object-cover"
					/>
				) : (
					<div class="w-9 h-9 rounded-lg admin-surface flex items-center justify-center font-semibold text-sm">
						{(user?.username || user?.name || "U").charAt(0).toUpperCase()}
					</div>
				)
			}
			<div class="flex-1 min-w-0">
				<p class="text-sm font-semibold truncate leading-tight">
					{user?.username || user?.name}
				</p>
				<p class="text-xs admin-muted truncate leading-tight">
					{user?.role}
				</p>
			</div>
			<!-- Theme Toggle -->
			<label class="swap swap-rotate h-8 w-8 rounded-lg hover:bg-[var(--admin-surface)] transition cursor-pointer relative flex items-center justify-center">
				<input type="checkbox" id="theme-toggle" />
				<!-- Sun icon (shown in dark mode) -->
				<svg class="swap-on w-4 h-4 fill-current absolute" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
					<path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/>
				</svg>
				<!-- Moon icon (shown in light mode) -->
				<svg class="swap-off w-4 h-4 fill-current absolute" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
					<path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"/>
				</svg>
			</label>
			<!-- Logout Button -->
			<button
				type="button"
				id="admin-logout-btn"
				class="h-8 w-8 rounded-lg hover:bg-red-500/20 transition flex items-center justify-center text-red-500"
				aria-label="Sign out"
			>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
				</svg>
			</button>
		</div>
	</div>
</aside>

<script>
	import { authClient } from "../lib/auth-client";

	// Highlight active navigation item
	document.addEventListener("DOMContentLoaded", () => {
		const currentPath = window.location.pathname;
		const navItems = document.querySelectorAll(".admin-nav-item");
		const themeToggle = document.getElementById("theme-toggle") as HTMLInputElement;
		const logoutBtn = document.getElementById("admin-logout-btn");

		// Theme toggle functionality
		if (themeToggle) {
			// Check for saved theme preference or default to 'light'
			const savedTheme = localStorage.getItem('admin-theme') || 'light';
			document.documentElement.setAttribute('data-theme', savedTheme);
			themeToggle.checked = savedTheme === 'dark';

			themeToggle.addEventListener('change', () => {
				const newTheme = themeToggle.checked ? 'dark' : 'light';
				document.documentElement.setAttribute('data-theme', newTheme);
				localStorage.setItem('admin-theme', newTheme);
			});
		}

		// Handle logout
		if (logoutBtn) {
			logoutBtn.addEventListener("click", async () => {
				try {
					await authClient.signOut();
					window.location.href = "/login";
				} catch (error) {
					console.error("Logout failed:", error);
					window.location.href = "/login";
				}
			});
		}

		navItems.forEach((item) => {
			const href = item.getAttribute("href");
			if (!href) return;

			let isActive = false;

			if (href === "/admin") {
				// Dashboard: exact match only
				isActive = currentPath === "/admin";
			} else if (href === "/admin/blogs") {
				// Blog Posts: match /admin/blogs and /admin/blogs/edit/* but NOT /admin/blogs/create
				isActive = currentPath === "/admin/blogs" ||
						   (currentPath.startsWith("/admin/blogs/") && !currentPath.startsWith("/admin/blogs/create"));
			} else if (href === "/admin/blogs/create") {
				// New Post: exact match only
				isActive = currentPath === "/admin/blogs/create";
			} else if (href === "/admin/categories") {
				// Categories: match /admin/categories exactly or subpaths
				isActive = currentPath === "/admin/categories" || currentPath.startsWith("/admin/categories/");
			} else if (href === "/admin/forums") {
				// Forums: match /admin/forums and subpaths
				isActive = currentPath === "/admin/forums" || currentPath.startsWith("/admin/forums/");
			} else if (href === "/admin/threads") {
				// Threads: match /admin/threads and subpaths
				isActive = currentPath === "/admin/threads" || currentPath.startsWith("/admin/threads/");
			} else if (href === "/admin/reports") {
				// Reports: match /admin/reports and subpaths
				isActive = currentPath === "/admin/reports" || currentPath.startsWith("/admin/reports/");
			} else if (href === "/admin/users") {
				// All Users: match /admin/users but NOT /admin/users/roles
				isActive = currentPath === "/admin/users" ||
						   (currentPath.startsWith("/admin/users/") && !currentPath.startsWith("/admin/users/roles"));
			} else if (href === "/admin/users/roles") {
				// Roles: match /admin/users/roles and subpaths
				isActive = currentPath === "/admin/users/roles" || currentPath.startsWith("/admin/users/roles/");
			} else if (href === "/admin/audit-logs") {
				// Audit Logs: match /admin/audit-logs and subpaths
				isActive = currentPath === "/admin/audit-logs" || currentPath.startsWith("/admin/audit-logs/");
			} else if (href === "/admin/metrics") {
				// Metrics: match /admin/metrics and subpaths
				isActive = currentPath === "/admin/metrics" || currentPath.startsWith("/admin/metrics/");
			} else if (href === "/admin/settings") {
				// Settings: match /admin/settings and subpaths
				isActive = currentPath === "/admin/settings" || currentPath.startsWith("/admin/settings/");
			}

			if (isActive) {
				item.classList.remove("admin-muted", "hover:bg-[var(--admin-surface-soft)]", "hover:text-[var(--admin-text)]");
				item.classList.add("text-[var(--admin-text)]", "font-semibold");
				(item as HTMLElement).style.background = "var(--admin-surface-soft)";
			}
		});
	});
</script>

<style>
	.custom-scrollbar::-webkit-scrollbar {
		width: 4px;
	}
	.custom-scrollbar::-webkit-scrollbar-track {
		background: transparent;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: hsl(var(--bc) / 0.2);
		border-radius: 2px;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb:hover {
		background: hsl(var(--bc) / 0.4);
	}
</style>
